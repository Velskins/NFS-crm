{% extends 'base.html.twig' %}
{% block title %}Nouveau RDV — {{ client.firstName }} {{ client.lastName }}{% endblock %}

{% block body %}
    <div class="detail-header">
        <div class="detail-header-left">
            <a href="{{ path('app_client_show', {'id': client.id}) }}" class="detail-back" title="Retour">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6"/>
                </svg>
            </a>
            <div>
                <h1 class="detail-title">Nouveau rendez-vous</h1>
                <p class="detail-subtitle">Client : {{ client.firstName }} {{ client.lastName }} — {{ client.companyName }}</p>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="inside-card">
            {{ form_start(form) }}
            {{ form_row(form.scheduleAt) }}
            {{ form_row(form.note) }}
            <button type="submit" class="btn btn-primary" style="margin-top: 16px;">📅 Confirmer le rendez-vous</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
