<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Définir mon mot de passe — Sphera</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}">
</head>
<body class="auth-page">

    <a href="{{ path('app_login') }}" class="auth-logo">
        <img src="{{ asset('images/logo-texte-sans_fond.png') }}" alt="Sphera">
    </a>

    <div class="auth-card">

        {% if expired %}
            <div class="alert alert-danger">
                Ce lien d'invitation a expiré ou est invalide. Contactez votre freelance pour recevoir un nouveau lien.
            </div>
            <a href="{{ path('app_login') }}" class="btn btn-primary auth-submit">
                Retour à la connexion
            </a>
        {% else %}

            {% for msg in app.flashes('danger') %}
                <div class="alert alert-danger">{{ msg }}</div>
            {% endfor %}

            {% for msg in app.flashes('success') %}
                <div class="alert alert-success">{{ msg }}</div>
            {% endfor %}

            <h2 style="text-align:center; margin-bottom: var(--space-4); font-size: var(--font-size-xl); font-weight: var(--font-weight-bold); color: var(--color-text);">
                Bienvenue, {{ user.firstname }} !
            </h2>

            <p class="auth-hint" style="margin-bottom: var(--space-6);">
                Définissez votre mot de passe pour accéder à votre espace client SPHERA.
            </p>

            <form method="post" novalidate>

                <div class="form-group">
                    <label class="form-label" for="password">Mot de passe</label>
                    <input
                        type="password"
                        class="form-control"
                        id="password"
                        name="password"
                        autocomplete="new-password"
                        required
                        minlength="6"
                        placeholder="Minimum 6 caractères"
                        autofocus
                    >
                </div>

                <div class="form-group">
                    <label class="form-label" for="password_confirm">Confirmer le mot de passe</label>
                    <input
                        type="password"
                        class="form-control"
                        id="password_confirm"
                        name="password_confirm"
                        autocomplete="new-password"
                        required
                        placeholder="Retapez votre mot de passe"
                    >
                </div>

                <button type="submit" class="btn btn-primary auth-submit">
                    Définir mon mot de passe
                </button>

            </form>

        {% endif %}

    </div>

</body>
</html>
