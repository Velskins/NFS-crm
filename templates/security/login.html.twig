<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion — Sphera</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}">
</head>
<body class="auth-page">

    <a href="{{ path('app_login') }}" class="auth-logo">
        <img src="{{ asset('images/logo-texte-sans_fond.png') }}" alt="Sphera">
    </a>

    <div class="auth-card">

        {% if error %}
            <div class="alert alert-danger">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}" novalidate>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label class="form-label" for="inputEmail">Email</label>
                <input
                    type="email"
                    class="form-control"
                    id="inputEmail"
                    name="email"
                    value="{{ last_username }}"
                    autocomplete="email"
                    autofocus
                    required
                    placeholder="votre@email.com"
                >
            </div>

            <div class="form-group">
                <label class="form-label" for="inputPassword">Mot de passe</label>
                <input
                    type="password"
                    class="form-control"
                    id="inputPassword"
                    name="password"
                    autocomplete="current-password"
                    required
                    placeholder="••••••••"
                >
            </div>

            <button type="submit" class="btn btn-primary auth-submit">
                Se connecter
            </button>

        </form>
    </div>

    <p class="auth-footer">
        Mot de passe oublié ?&nbsp;<a href="{{ path('app_forgot_password') }}">Cliquez ici</a>
    </p>

</body>
</html>
