<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mot de passe oublié — Sphera</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg:        #ECEAE6;
            --card:      #F2F0EC;
            --primary:   #5047E5;
            --btn:       #5047E5;
            --input-bg:  #E5E3DE;
            --label:     #5047E5;
            --text:      #1E2340;
            --muted:     #7A7A8C;
            --shadow-out: 6px 6px 16px rgba(0,0,0,0.12), -4px -4px 12px rgba(255,255,255,0.85);
            --shadow-in:  inset 3px 3px 8px rgba(0,0,0,0.10), inset -3px -3px 8px rgba(255,255,255,0.75);
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin-bottom: 2.5rem;
            text-decoration: none;
        }
        .logo img { height: 60px; width: auto; }

        /* Wrapper carte + bouton retour */
        .card-wrapper {
            position: relative;
            width: 100%;
            max-width: 520px;
        }

        /* Bouton retour */
        .btn-back {
            position: absolute;
            left: -56px;
            top: 16px;
            width: 40px;
            height: 40px;
            background: var(--card);
            border: none;
            border-radius: 10px;
            box-shadow: var(--shadow-out);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            text-decoration: none;
            color: var(--text);
            transition: transform 0.15s;
        }
        .btn-back:hover { transform: translateX(-2px); }
        .btn-back svg { width: 20px; height: 20px; }

        .card {
            background: var(--card);
            border-radius: 28px;
            box-shadow: var(--shadow-out);
            padding: 2.5rem 2.75rem 2.75rem;
            width: 100%;
        }

        .form-group { margin-bottom: 0.5rem; }
        .form-group label {
            display: block;
            font-weight: 700;
            font-size: 1rem;
            color: var(--label);
            margin-bottom: 0.6rem;
        }
        .form-group input {
            width: 100%;
            background: var(--input-bg);
            border: none;
            border-radius: 50px;
            padding: 0.85rem 1.4rem;
            font-family: 'Outfit', sans-serif;
            font-size: 1rem;
            color: var(--text);
            box-shadow: var(--shadow-in);
            outline: none;
            transition: box-shadow 0.2s;
        }
        .form-group input:focus {
            box-shadow: inset 3px 3px 8px rgba(0,0,0,0.12), inset -3px -3px 8px rgba(255,255,255,0.75), 0 0 0 2px rgba(80,71,229,0.25);
        }

        .hint {
            font-size: 0.88rem;
            color: var(--muted);
            text-align: center;
            margin-top: 0.75rem;
            line-height: 1.5;
        }

        {% if success is defined and success %}
        .alert-success {
            background: #e5f9ee;
            color: #1e7e45;
            border-radius: 12px;
            padding: 0.75rem 1.2rem;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
            font-weight: 500;
        }
        {% endif %}

        .btn-submit {
            display: block;
            width: fit-content;
            margin: 2.25rem auto 0;
            background: var(--btn);
            color: #fff;
            border: none;
            border-radius: 50px;
            padding: 0.85rem 3.5rem;
            font-family: 'Outfit', sans-serif;
            font-size: 0.95rem;
            font-weight: 800;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            cursor: pointer;
            box-shadow: 4px 4px 12px rgba(80,71,229,0.35), -2px -2px 8px rgba(255,255,255,0.6);
            transition: transform 0.15s, box-shadow 0.15s;
        }
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 6px 6px 18px rgba(80,71,229,0.4), -2px -2px 8px rgba(255,255,255,0.6);
        }

        @media (max-width: 600px) {
            .btn-back { display: none; }
            .card { padding: 2rem 1.5rem 2.25rem; }
            .logo img { height: 48px; }
        }
    </style>
</head>
<body>

    <a href="{{ path('app_login') }}" class="logo">
        <img src="{{ asset('images/logo-texte-sans_fond.png') }}" alt="Sphera">
    </a>

    <div class="card-wrapper">

        <a href="{{ path('app_login') }}" class="btn-back" title="Retour à la connexion">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 8 8 12 12 16"/>
                <line x1="16" y1="12" x2="8" y2="12"/>
            </svg>
        </a>

        <div class="card">

            {% if app.session.flashBag.has('success') %}
                {% for msg in app.session.flashBag.get('success') %}
                    <div class="alert-success">{{ msg }}</div>
                {% endfor %}
            {% endif %}

            <form method="post" action="{{ path('app_forgot_password') }}" novalidate>

                <div class="form-group">
                    <label for="inputEmail">Email</label>
                    <input
                        type="email"
                        id="inputEmail"
                        name="email"
                        autocomplete="email"
                        autofocus
                        required
                        placeholder="votre@email.com"
                    >
                </div>

                <p class="hint">Vous allez recevoir un lien via email permettant de<br>modifier votre mot de passe</p>

                <button type="submit" class="btn-submit">Envoyer</button>

            </form>
        </div>
    </div>

</body>
</html>
