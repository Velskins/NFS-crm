<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mot de passe oublié — Sphera</title>
    <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    <link rel="stylesheet" href="{{ asset('styles/auth.css') }}">
</head>
<body class="auth-page">

    <a href="{{ path('app_login') }}" class="auth-logo">
        <img src="{{ asset('images/logo-texte-sans_fond.png') }}" alt="Sphera">
    </a>

    <div class="auth-card-wrapper">

        <a href="{{ path('app_login') }}" class="btn-back" title="Retour à la connexion">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 8 8 12 12 16"/>
                <line x1="16" y1="12" x2="8" y2="12"/>
            </svg>
        </a>

        <div class="auth-card">

            {% for msg in app.flashes('success') %}
                <div class="alert alert-success">{{ msg }}</div>
            {% endfor %}

            <form method="post" action="{{ path('app_forgot_password') }}" novalidate>

                <div class="form-group">
                    <label class="form-label" for="inputEmail">Email</label>
                    <input
                        type="email"
                        class="form-control"
                        id="inputEmail"
                        name="email"
                        autocomplete="email"
                        autofocus
                        required
                        placeholder="votre@email.com"
                    >
                </div>

                <p class="auth-hint">
                    Vous allez recevoir un lien via email permettant de<br>modifier votre mot de passe
                </p>

                <button type="submit" class="btn btn-primary auth-submit">
                    Envoyer
                </button>

            </form>
        </div>

    </div>

</body>
</html>
