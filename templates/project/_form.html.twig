{{ form_start(form, {'attr': {'class': 'client-form', 'id': 'project-form', 'novalidate': 'novalidate'}}) }}

    {# ── Ligne 1 : Titre / Statut ── #}
<div class="client-form-row">
    <div class="client-form-field">
        <label class="client-form-label">Titre du projet</label>
        <div class="client-form-input-wrap">
            <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
            {{ form_widget(form.title, {'attr': {'class': 'client-form-input', 'placeholder': 'Ex : Refonte site web'}}) }}
        </div>
        {{ form_errors(form.title) }}
    </div>
    <div class="client-form-field">
        <label class="client-form-label">Statut</label>
        <div class="client-form-input-wrap">
            <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            {{ form_widget(form.status, {'attr': {'class': 'client-form-input client-form-select'}}) }}
        </div>
        {{ form_errors(form.status) }}
    </div>
</div>

{# ── Ligne 2 : Budget / Client ── #}
<div class="client-form-row">
    <div class="client-form-field">
        <label class="client-form-label">Budget (€)</label>
        <div class="client-form-input-wrap">
            <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
            {{ form_widget(form.budget, {'attr': {'class': 'client-form-input client-form-money'}}) }}
        </div>
        {{ form_errors(form.budget) }}
    </div>
    <div class="client-form-field">
        <label class="client-form-label">Client</label>
        <div class="client-form-input-wrap">
            <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
            {{ form_widget(form.client, {'attr': {'class': 'client-form-input client-form-select'}}) }}
        </div>
        {{ form_errors(form.client) }}
    </div>
</div>

{# ── Ligne 3 : Deadline du Projet ── #}
<div class="client-form-row client-form-row--full">
    <div class="client-form-field">
        <label class="client-form-label">Date limite du projet</label>
        <div class="client-form-input-wrap">
            <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            {{ form_widget(form.deadline, {'attr': {'class': 'client-form-input'}}) }}
        </div>
        {{ form_errors(form.deadline) }}
    </div>
</div>

{# ── Section Tâches ── #}
<div class="client-form-row client-form-row--full" style="margin-top: 40px;">
    <div class="project-tasks-section">
        <div class="project-tasks-header">
            <h3 class="project-tasks-title">Tâches</h3>
            <button type="button" id="add-task" class="btn btn-primary project-tasks-add">+ Ajouter une tâche</button>
        </div>

        <ul id="task-list"
            data-prototype="{{ form_widget(form.tasks.vars.prototype)|e('html_attr') }}"
            data-index="{{ form.tasks|length }}"
            class="project-task-list">

            {% for task in form.tasks %}
                <li class="project-task-item">
                    <div class="client-form-row">
                        <div class="client-form-field">
                            <label class="client-form-label">Nom de la tâche</label>
                            {{ form_widget(task.title, {'attr': {'class': 'client-form-input'}}) }}
                        </div>
                        <div class="client-form-field">
                            <label class="client-form-label">Statut</label>
                            {{ form_widget(task.status, {'attr': {'class': 'client-form-input'}}) }}
                        </div>
                    </div>
                    {# REPOSITIONNEMENT DE LA DATE DE LA TÂCHE #}
                    <div class="client-form-row client-form-row--full" style="margin-top: 10px;">
                        <div class="client-form-field">
                            <label class="client-form-label">Date limite de la tâche</label>
                            {{ form_widget(task.deadline, {'attr': {'class': 'client-form-input'}}) }}
                        </div>
                    </div>
                    <button type="button" class="project-task-remove">Supprimer</button>
                </li>
            {% endfor %}
        </ul>
    </div>
</div>

{# ── Section Échéances de Paiement ── #}
<div class="client-form-row client-form-row--full" style="margin-top: 40px;">
    <div class="project-tasks-section" style="border-top: 1px solid #eee; padding-top: 20px;">
        <div class="project-tasks-header">
            <h3 class="project-tasks-title">Échéances de paiement</h3>
            <button type="button" id="add-payment" class="btn btn-primary project-tasks-add">+ Ajouter une échéance</button>
        </div>

        <ul id="payment-list"
            data-prototype="{{ form_widget(form.paymentSchedules.vars.prototype)|e('html_attr') }}"
            data-index="{{ form.paymentSchedules|length }}"
            class="project-task-list">

            {% for payment in form.paymentSchedules %}
                <li class="project-task-item">
                    <div class="client-form-row">
                        <div class="client-form-field">
                            <label class="client-form-label">Montant (€)</label>
                            {{ form_widget(payment.amount, {'attr': {'class': 'client-form-input'}}) }}
                        </div>
                        <div class="client-form-field">
                            <label class="client-form-label">Date d'échéance</label>
                            {{ form_widget(payment.dueDate, {'attr': {'class': 'client-form-input'}}) }}
                        </div>
                    </div>
                    <button type="button" class="project-task-remove">Supprimer</button>
                </li>
            {% endfor %}
        </ul>
    </div>
</div>

<div class="client-form-submit">
    <button type="submit" class="btn btn-primary">{{ button_label|default('Créer le projet') }}</button>
</div>

{# Sécurité pour éviter les labels automatiques de Symfony en fin de page #}
    {% do form.tasks.setRendered %}
    {% do form.paymentSchedules.setRendered %}

{{ form_end(form) }}

<script>
    function setupCollection(buttonId, listId, itemClass) {
        const btn = document.getElementById(buttonId);
        const list = document.getElementById(listId);
        if (!btn || !list) return;

        btn.addEventListener('click', function () {
            const prototype = list.dataset.prototype;
            const index = list.dataset.index;
            const newForm = prototype.replace(/__name__/g, index);
            const li = document.createElement('li');
            li.className = itemClass;
            const tmp = document.createElement('div');
            tmp.innerHTML = newForm;

            // On applique le style Sphera à tous les champs générés
            tmp.querySelectorAll('input, select').forEach(el => {
                el.classList.add('client-form-input');
                if (el.tagName === 'SELECT') el.classList.add('client-form-select');
            });

            li.innerHTML = tmp.innerHTML;

            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'project-task-remove';
            removeBtn.innerHTML = 'Supprimer';
            removeBtn.onclick = () => li.remove();
            li.appendChild(removeBtn);

            list.appendChild(li);
            list.dataset.index = parseInt(index) + 1;
        });
    }

    setupCollection('add-task', 'task-list', 'project-task-item');
    setupCollection('add-payment', 'payment-list', 'project-task-item');

    // Gestion de la suppression pour les éléments existants au chargement
    document.addEventListener('click', function(e) {
        if (e.target.classList.contains('project-task-remove')) {
            e.target.closest('li').remove();
        }
    });
</script>
