{% extends 'base.html.twig' %}

{% block title %}Mes Projets{% endblock %}

{% block body %}
    <h1>Mes Projets</h1>

    <table class="table">
        <thead>
        <tr>
            <th>Titre</th>
            <th>Client</th>
            <th>Budget</th>
            <th>Statut</th>
            <th>Créé le</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for project in projects %}
            <tr>
                <td>{{ project.title }}</td>
                <td>{{ project.client.companyName }}</td>
                <td>{{ project.budget }} €</td>
                <td>{{ project.status }}</td>
                <td>{{ project.createdAt ? project.createdAt|date('d/m/Y') : '-' }}</td>
                <td>
                    <a href="{{ path('app_project_show', {'id': project.id}) }}">Voir</a>
                    <a href="{{ path('app_project_edit', {'id': project.id}) }}">Modifier</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">Aucun projet pour l'instant.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_project_new') }}">+ Nouveau projet</a>
{% endblock %}
