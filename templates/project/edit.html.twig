{% extends 'base.html.twig' %}

{% block title %}Modifier {{ project.title }} — Sphera{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('styles/project.css') }}">
{% endblock %}

{% block body %}

    <div class="card">
        <div class="inside-card">

            <div class="client-form-header">
                <h2 class="client-form-title">Modifier le projet</h2>
                <a href="{{ path('app_project_index') }}" class="dash-card-link">Retour à la liste</a>
            </div>

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {{ include('project/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}

            <div style="margin-top: var(--space-6); padding-top: var(--space-4); border-top: 1px solid rgba(194,192,191,0.3);">
                {{ include('project/_delete_form.html.twig') }}
            </div>

        </div>
    </div>

{% endblock %}
