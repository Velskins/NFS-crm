    {# ══════════════════════════════════════════════════════
       BOTTOM ROW : Calendrier + Clients
       ══════════════════════════════════════════════════════ #}
    <div class="dash-bottom">

        {# ── Calendrier ── #}
        <div class="dash-card">
            <div class="dash-card-header">
                <h2 class="dash-card-title">Calendrier</h2>
                <select class="dash-cal-select">
                    <option>Mars</option>
                    <option>Avril</option>
                    <option>Mai</option>
                </select>
            </div>

            {# Jours de la semaine #}
            <div class="dash-cal-days">
                <div class="dash-cal-day"></div>{# Espace pour la colonne heure #}
                <div class="dash-cal-day">Lun <span class="dash-cal-day-num">21</span></div>
                <div class="dash-cal-day">Mar <span class="dash-cal-day-num">22</span></div>
                <div class="dash-cal-day">Mer <span class="dash-cal-day-num">23</span></div>
                <div class="dash-cal-day">Jeu <span class="dash-cal-day-num">24</span></div>
                <div class="dash-cal-day today">Ven <span class="dash-cal-day-num">25</span></div>
                <div class="dash-cal-day">Sam <span class="dash-cal-day-num">26</span></div>
                <div class="dash-cal-day">Dim <span class="dash-cal-day-num">27</span></div>
            </div>

            {# Grille horaire #}
            <div class="dash-cal-grid">
                <div class="dash-cal-hour">8 h</div>
                <div class="dash-cal-slot"></div>

                <div class="dash-cal-hour">9 h</div>
                <div class="dash-cal-slot">
                    <div class="dash-cal-task">
                        <div class="dash-cal-task-title">Tâche: Finir Maquette CRM</div>
                        <div class="dash-cal-task-time">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            09:15 h à 10:45 h
                        </div>
                    </div>
                </div>

                <div class="dash-cal-hour">10 h</div>
                <div class="dash-cal-slot"></div>

                <div class="dash-cal-hour">11 h</div>
                <div class="dash-cal-slot">
                    <div class="dash-cal-task">
                        <div class="dash-cal-task-title">Tâche: V1 maquette Client</div>
                        <div class="dash-cal-task-time">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            11:45 h à 12:35 h
                        </div>
                    </div>
                </div>

                <div class="dash-cal-hour">12 h</div>
                <div class="dash-cal-slot"></div>
            </div>
        </div>

