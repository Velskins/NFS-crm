{{ form_start(form, {'attr': {'class': 'client-form', 'id': 'client-form', 'novalidate': 'novalidate'}}) }}

    {# ── Ligne 1 : Nom / Prénom ── #}
    <div class="client-form-row">
        <div class="client-form-field">
            <label class="client-form-label">Nom</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
                {{ form_widget(form.lastName, {'attr': {'class': 'client-form-input', 'placeholder': 'Nom du client'}}) }}
            </div>
            {{ form_errors(form.lastName) }}
        </div>
        <div class="client-form-field">
            <label class="client-form-label">Prénom</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
                {{ form_widget(form.firstName, {'attr': {'class': 'client-form-input', 'placeholder': 'Prénom du client'}}) }}
            </div>
            {{ form_errors(form.firstName) }}
        </div>
    </div>

    {# ── Ligne 2 : Entreprise / Secteur ── #}
    <div class="client-form-row">
        <div class="client-form-field">
            <label class="client-form-label">Entreprise</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
                {{ form_widget(form.companyName, {'attr': {'class': 'client-form-input', 'placeholder': "Nom de l'entreprise"}}) }}
            </div>
            {{ form_errors(form.companyName) }}
        </div>
        <div class="client-form-field">
            <label class="client-form-label">Secteur d'activité</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
                {{ form_widget(form.businessSector, {'attr': {'class': 'client-form-input', 'placeholder': "Secteur d'activité de l'entreprise"}}) }}
            </div>
            {{ form_errors(form.businessSector) }}
        </div>
    </div>

    {# ── Ligne 3 : Email / Téléphone ── #}
    <div class="client-form-row">
        <div class="client-form-field">
            <label class="client-form-label">Email</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
                </svg>
                {{ form_widget(form.email, {'attr': {'class': 'client-form-input', 'placeholder': 'Adresse email du client'}}) }}
            </div>
            {{ form_errors(form.email) }}
        </div>
        <div class="client-form-field">
            <label class="client-form-label">Téléphone</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                {{ form_widget(form.phone, {'attr': {'class': 'client-form-input', 'placeholder': 'Numéro du client'}}) }}
            </div>
            {{ form_errors(form.phone) }}
        </div>
    </div>

    {# ── Ligne 4 : Adresse (pleine largeur) ── #}
    <div class="client-form-row client-form-row--full">
        <div class="client-form-field">
            <label class="client-form-label">Adresse</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/>
                </svg>
                {{ form_widget(form.address, {'attr': {'class': 'client-form-input', 'placeholder': 'Entrez la localisation du client'}}) }}
            </div>
            {{ form_errors(form.address) }}
        </div>
    </div>

    {# ── Champs cachés : ville, code postal (pas sur la maquette mais dans l'entité) ── #}
    <div class="client-form-row">
        <div class="client-form-field">
            <label class="client-form-label">Ville</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/>
                </svg>
                {{ form_widget(form.city, {'attr': {'class': 'client-form-input', 'placeholder': 'Ville'}}) }}
            </div>
            {{ form_errors(form.city) }}
        </div>
        <div class="client-form-field">
            <label class="client-form-label">Code postal</label>
            <div class="client-form-input-wrap">
                <svg class="client-form-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="10" r="3"/><path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z"/>
                </svg>
                {{ form_widget(form.postalCode, {'attr': {'class': 'client-form-input', 'placeholder': 'Code postal'}}) }}
            </div>
            {{ form_errors(form.postalCode) }}
        </div>
    </div>

    {# ── Notes (zone document dans la maquette) ── #}
    <div class="client-form-row client-form-row--full">
        <div class="client-form-field">
            <label class="client-form-label">Notes</label>
            <div class="client-form-textarea-wrap">
                {{ form_widget(form.notes, {'attr': {'class': 'client-form-textarea', 'placeholder': 'Notes ou informations complémentaires...', 'rows': 4}}) }}
            </div>
            {{ form_errors(form.notes) }}
        </div>
    </div>

<div class="client-form-submit">
        <button type="submit" class="btn btn-primary">{{ button_label|default('Ajouter un client') }}</button>
    </div>

{{ form_end(form) }}
