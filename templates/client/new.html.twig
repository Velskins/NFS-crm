{% extends 'base.html.twig' %}

{% block title %}Nouveau client — Sphera{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/clients.css') }}">
{% endblock %}

{% block body %}

    {# ── Card principale ── #}
    <div class="card">
        <div class="inside-card">

            {# Header fieldset style #}
            <div class="client-form-header">
                <h2 class="client-form-title">Détails du client</h2>
            </div>

            {# ── Flash messages ── #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }}">{{ message }}</div>
                {% endfor %}
            {% endfor %}

            {{ include('client/_form.html.twig') }}

        </div>{# /inside-card #}
    </div>

{% endblock %}
